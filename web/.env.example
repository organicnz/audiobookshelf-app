# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in your Supabase project → Settings → API

# These are the ONLY env vars you need to set. The NUXT_PUBLIC_ prefix tells
# Nuxt to expose them to the browser via useRuntimeConfig().public and also
# satisfies the @nuxtjs/supabase module's url/key config.
NUXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: service role key for server-side admin operations (never expose to browser)
# SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Vercel ───────────────────────────────────────────────────────────────────
# Set these in your Vercel project → Settings → Environment Variables:
#   NUXT_PUBLIC_SUPABASE_URL
#   NUXT_PUBLIC_SUPABASE_ANON_KEY
